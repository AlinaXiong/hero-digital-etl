# 复制本文件为 .env 并填入真实账密。.env 已被 .gitignore 忽略,不会提交到版本库。
# 泛微生产库(取工号)
FW_HOST=gz-cdbrg-xxxxxxxx.sql.tencentcdb.com
FW_PORT=58342
FW_USER=填写账号
FW_PASS=填写密码
# 业财中台库(取供应商编码)
ZT_HOST=sh-cdb-xxxxxxxx.sql.tencentcdb.com
ZT_PORT=22859
ZT_USER=填写账号
ZT_PASS=填写密码

# 汉得生产环境(通过 SSH 跳板连接 MySQL)。
# 设置 HAND_AS_ZT=1 后,现有 c.query_db('ZT', ...) 会自动改走 HAND,无需逐个改业务代码。
HAND_AS_ZT=1
HAND_HOST=172.17.1.62
HAND_PORT=3306
HAND_USER=填写账号
HAND_PASS=填写密码
HAND_SSH_ENABLED=1
HAND_SSH_HOST=124.222.98.206
HAND_SSH_PORT=22
HAND_SSH_USER=填写跳板机账号
HAND_SSH_PASS=填写跳板机密码

# 飞书(corehr)应用凭据: 取员工在职/离职状态判断"申请人状态"。为空时该列留空,不影响其它字段。
FEISHU_APP_ID=填写飞书自建应用 App ID
FEISHU_APP_SECRET=填写飞书自建应用 App Secret

# 泛微合同附件下载 Cookie。为空时只生成附件名称清单,不下载附件文件。
WEAVER_CONTRACT_ATTACHMENT_COOKIE=
# 以下为可选参数,一般不用改。
WEAVER_CONTRACT_ATTACHMENT_BASE_URL=http://oaportal.heroesports.com
WEAVER_CONTRACT_ATTACHMENT_LOGIN_USERID=3837
WEAVER_CONTRACT_ATTACHMENT_AUTHORIZEMODE_ID=5
WEAVER_CONTRACT_ATTACHMENT_AUTHORIZEFIELD_ID=6461
WEAVER_CONTRACT_ATTACHMENT_DOWNLOAD_ROOT=
WEAVER_CONTRACT_ATTACHMENT_DOWNLOAD_ENABLED=1
